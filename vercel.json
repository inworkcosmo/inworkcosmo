{
  "redirects": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "app.workcosmo.in"
        }
      ],
      "destination": "https://space.workcosmo.in",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/reset-password",
      "destination": "/reset-password.html"
    }
  ]
}
